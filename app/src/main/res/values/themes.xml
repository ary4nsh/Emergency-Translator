<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Default alias referenced in AndroidManifest.xml -->
    <style name="Theme.EmergencyTranslator" parent="Theme.EmergencyTranslator.Light.Blue" />

    <!-- Splash: always red window background; setTheme() in MainActivity overrides the rest -->
    <style name="Theme.EmergencyTranslator.Splash" parent="Theme.EmergencyTranslator.Light.Red">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
    </style>

    <!-- ── White + Blue ───────────────────────────────────────────────── -->
    <style name="Theme.EmergencyTranslator.Light.Blue" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_light_primary</item>
        <item name="colorOnPrimary">@color/blue_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/blue_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/blue_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/blue_light_secondary</item>
        <item name="colorOnSecondary">@color/blue_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/blue_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/blue_light_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorOnBackground">@color/light_onBackground</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_onSurface</item>
        <item name="colorSurfaceVariant">@color/light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/light_onSurfaceVariant</item>
        <item name="colorOutline">@color/light_outline</item>
        <item name="colorError">@color/light_error</item>
        <item name="colorOnError">@color/light_onError</item>
        <item name="android:navigationBarColor">@color/light_background</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

